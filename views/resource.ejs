<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <% var pageTitle = 'Resources | LEX Briefly'; %>
    <%- include('partials/head') %>
</head>
<body class="flex bg-rich-black text-white-text selection:bg-royal-blue selection:text-white-text">

    <%- include('partials/sidebar') %>
    <%- include('partials/mobile-drawer') %>

    <div id="mainContent" class="flex-1 transition-all duration-300 md:ml-64 relative min-h-screen">
        <%- include('partials/header') %>

        <main class="pt-24 pb-20 px-6 md:px-12 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-royal-blue/10 via-rich-black to-rich-black min-h-screen">

            <section class="max-w-4xl mx-auto text-center mb-12">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-gold/30 bg-deep-navy/50 text-gold text-xs font-semibold uppercase tracking-wider mb-4 backdrop-blur-sm">
                    <i class="ph-fill ph-books text-royal-yellow"></i>
                    Semester-wise Learning Hub
                </div>
                <h1 class="font-heading text-4xl md:text-5xl font-bold text-white-text mb-4 drop-shadow-lg">Resources</h1>
                <p class="text-light-gray text-base md:text-lg">
                    Access semester-wise study materials, case materials, notes, previous year papers and video lectures for all LL.B. subjects.
                </p>
            </section>

            <section class="max-w-3xl mx-auto mb-10">
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 flex items-center pl-5 pointer-events-none">
                        <i class="ph ph-magnifying-glass text-xl text-light-gray group-focus-within:text-royal-blue transition-colors"></i>
                    </div>
                    <input type="text" id="subjectSearch" class="w-full bg-deep-navy/50 border border-gold/20 text-white-text text-base rounded-full focus:ring-2 focus:ring-royal-blue focus:border-royal-blue block pl-14 p-4 transition-all placeholder-light-gray/50 shadow-lg" placeholder="Search Subject Name or Code...">
                </div>
            </section>

            <section class="mb-12">
                <div class="flex flex-wrap justify-center gap-3">
                    <% semesters.forEach(function(sem, i) { %>
                        <button
                            class="tab-btn <%= i === 0 ? 'active bg-royal-blue text-white-text border-royal-blue' : 'bg-deep-navy/50 text-light-gray border-gold/20 hover:border-gold hover:text-white-text' %> border px-6 py-2.5 rounded-full font-medium text-sm transition-all shadow-lg"
                            data-target="<%= sem.key %>"
                        ><%= sem.label %></button>
                    <% }); %>
                </div>
            </section>

            <section id="subjectsContainer" class="max-w-[1400px] mx-auto">
                <% semesters.forEach(function(sem, i) { %>
                    <div id="<%= sem.key %>" class="tab-content grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 <%= i === 0 ? 'animate-fade-in' : 'hidden' %>">
                        <% (subjectsBySemester[sem.key] || []).forEach(function(sub) { %>
                            <div class="subject-card glass-card p-6 rounded-xl flex flex-col group hover:border-royal-blue/50 transition-all duration-300">
                                <span class="bg-royal-blue/20 text-royal-blue text-xs font-bold px-3 py-1 rounded w-fit subject-code mb-4"><%= sub.code %></span>
                                <h3 class="text-lg font-bold text-white-text mb-4 font-heading subject-name leading-snug group-hover:text-gold transition-colors"><%= sub.name %></h3>
                                <div class="h-px w-full bg-gold/10 my-4"></div>
                                <div class="flex flex-col gap-2.5 mt-auto">
                                    <% categories.forEach(function(cat) { %>
                                        <% var tileCount = countMap[sem.key + '|' + sub.code + '|' + cat.key] || 0; %>
                                        <a href="/resource/<%= sem.key %>/<%= sub.code %>/<%= cat.key %>" class="flex items-center justify-between gap-3 text-sm text-light-gray hover:text-white-text bg-deep-navy/40 hover:bg-royal-blue/80 p-3 rounded-lg transition-all border border-transparent hover:border-royal-blue/30">
                                            <span class="flex items-center gap-3"><span class="text-lg"><%= cat.icon %></span> <%= cat.label %></span>
                                            <% if (tileCount > 0) { %>
                                                <span class="text-[11px] font-semibold bg-royal-blue/20 text-royal-blue rounded-full px-2 py-0.5"><%= tileCount %></span>
                                            <% } %>
                                        </a>
                                    <% }); %>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% }); %>
            </section>
        </main>

        <%- include('partials/footer') %>
    </div>

    <%- include('partials/scripts') %>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // --- Semester Tabs Logic ---
            const tabBtns = document.querySelectorAll('.tab-btn');
            const tabContents = document.querySelectorAll('.tab-content');
            const searchInput = document.getElementById('subjectSearch');

            tabBtns.forEach((btn) => {
                btn.addEventListener('click', () => {
                    tabBtns.forEach((b) => {
                        b.classList.remove('active', 'bg-royal-blue', 'text-white-text', 'border-royal-blue');
                        b.classList.add('bg-deep-navy/50', 'text-light-gray', 'border-gold/20');
                    });
                    btn.classList.add('active', 'bg-royal-blue', 'text-white-text', 'border-royal-blue');
                    btn.classList.remove('bg-deep-navy/50', 'text-light-gray', 'border-gold/20');

                    const targetId = btn.getAttribute('data-target');

                    tabContents.forEach((content) => {
                        content.classList.add('hidden');
                        content.classList.remove('animate-fade-in');
                    });

                    const activeContent = document.getElementById(targetId);
                    activeContent.classList.remove('hidden');
                    void activeContent.offsetWidth;
                    activeContent.classList.add('animate-fade-in');

                    if (searchInput) searchInput.dispatchEvent(new Event('input'));
                });
            });

            // --- Live Search Logic ---
            if (searchInput) {
                searchInput.addEventListener('input', (e) => {
                    const term = e.target.value.toLowerCase();
                    const activeTab = document.querySelector('.tab-content:not(.hidden)');
                    if (!activeTab) return;

                    const cards = activeTab.querySelectorAll('.subject-card');
                    cards.forEach((card) => {
                        const code = card.querySelector('.subject-code').textContent.toLowerCase();
                        const name = card.querySelector('.subject-name').textContent.toLowerCase();
                        card.style.display = (code.includes(term) || name.includes(term)) ? 'flex' : 'none';
                    });
                });
            }
        });
    </script>
</body>
</html>
