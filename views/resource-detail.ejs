<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <% var pageTitle = subjectInfo.name + ' — ' + categoryInfo.label + ' | LEX Briefly'; %>
    <%- include('partials/head') %>
</head>
<body class="flex bg-rich-black text-white-text selection:bg-royal-blue selection:text-white-text">

    <%- include('partials/sidebar') %>
    <%- include('partials/mobile-drawer') %>

    <div id="mainContent" class="flex-1 transition-all duration-300 md:ml-64 relative min-h-screen">
        <%- include('partials/header') %>

        <main class="pt-24 pb-20 px-6 md:px-12 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-royal-blue/10 via-rich-black to-rich-black min-h-screen">

            <nav class="max-w-5xl mx-auto mb-6 text-sm text-light-gray/70 flex items-center gap-2 flex-wrap">
                <a href="/resource.html" class="hover:text-royal-yellow transition-colors">Resources</a>
                <i class="ph ph-caret-right text-xs"></i>
                <span class="text-light-gray"><%= semesterInfo.label %></span>
                <i class="ph ph-caret-right text-xs"></i>
                <span class="text-light-gray"><%= subjectInfo.code %></span>
                <i class="ph ph-caret-right text-xs"></i>
                <span class="text-gold font-medium"><%= categoryInfo.label %></span>
            </nav>

            <section class="max-w-5xl mx-auto mb-10">
                <div class="glass-card rounded-2xl p-8 flex flex-col md:flex-row md:items-center gap-6 justify-between">
                    <div class="flex items-start gap-4">
                        <div class="w-14 h-14 rounded-xl bg-royal-blue/15 border border-royal-blue/20 flex items-center justify-center shrink-0">
                            <i class="ph-fill <%= categoryInfo.pageIcon %> text-3xl text-gold"></i>
                        </div>
                        <div>
                            <span class="bg-royal-blue/20 text-royal-blue text-xs font-bold px-3 py-1 rounded w-fit inline-block mb-2"><%= subjectInfo.code %></span>
                            <h1 class="font-heading text-2xl md:text-3xl font-bold text-white-text mb-1"><%= subjectInfo.name %></h1>
                            <p class="text-light-gray text-sm"><%= categoryInfo.label %> · <%= semesterInfo.label %></p>
                        </div>
                    </div>
                    <a href="/resource.html" class="btn-secondary px-5 py-2.5 rounded-full text-sm inline-flex items-center gap-2 shrink-0">
                        <i class="ph ph-arrow-left"></i> Back to Resources
                    </a>
                </div>
            </section>

            <section class="max-w-5xl mx-auto">
                <% if (items && items.length) { %>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                        <% items.forEach(item => { %>
                            <%- include('partials/content-card', { item }) %>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="glass-card rounded-2xl p-12 text-center max-w-xl mx-auto">
                        <i class="ph ph-tray text-4xl text-light-gray/40 mb-4"></i>
                        <p class="text-light-gray">Nothing has been published to this tile yet. Check back soon — CMS staff add content regularly.</p>
                    </div>
                <% } %>
            </section>
        </main>

        <%- include('partials/footer') %>
    </div>

    <%- include('partials/scripts') %>
</body>
</html>