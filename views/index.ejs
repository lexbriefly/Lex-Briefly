<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <% var pageTitle = 'LEX Briefly | Faculty of Law, University of Delhi'; %>
    <%- include('partials/head') %>
</head>
<body class="flex bg-rich-black text-white-text selection:bg-royal-blue selection:text-white-text">

    <%- include('partials/sidebar') %>
    <%- include('partials/mobile-drawer') %>

    <div id="mainContent" class="flex-1 transition-all duration-300 md:ml-64 relative min-h-screen">
        <%- include('partials/header') %>

        <main>
            <!-- Hero Section -->
            <section class="relative min-h-screen flex items-center pt-20 overflow-hidden bg-hero-pattern">
                <canvas id="particle-canvas"></canvas>
                <svg class="watermark" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
                    <path d="M224,112h-84.4l-7.3-65.7a8,8,0,0,0-15.9,1.7l7.1,64H40a8,8,0,0,0,0,16H98.9l-19.1,66.8A24,24,0,0,0,103,222.1l1.5-.4A24.1,24.1,0,0,0,120,200l17.7-61.9L155.4,200a24.1,24.1,0,0,0,15.5,21.7l1.5.4a24,24,0,0,0,23.2-27.3l-19.1-66.8H224a8,8,0,0,0,0-16ZM102,192.3l15-52.5,15,52.5a8.1,8.1,0,0,1-5.1,10,8.2,8.2,0,0,1-19.8-10Zm61,10a8.1,8.1,0,0,1-5.1-10l15-52.5,15,52.5a8.2,8.2,0,0,1-19.8,10ZM128,40a8,8,0,0,0,8-8V16a8,8,0,0,0-16,0V32A8,8,0,0,0,128,40Z"/>
                </svg>

                <div class="container mx-auto px-6 md:px-12 relative z-10 grid lg:grid-cols-2 gap-12 items-center">
                    <div class="max-w-2xl reveal">
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-gold/30 bg-deep-navy/50 text-gold text-xs font-semibold uppercase tracking-wider mb-8 backdrop-blur-sm">
                            <i class="ph-fill ph-sparkle text-royal-yellow"></i>
                            Welcome to the New Era of Legal Learning
                        </div>

                        <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-4 drop-shadow-xl">
                            <span class="block text-white-text">LEX Briefly</span>
                        </h1>
                        <h2 class="text-xl md:text-2xl font-light text-light-gray mb-6 border-l-4 border-royal-blue pl-4">
                            Faculty of Law <br> <span class="font-medium text-gold">University of Delhi</span>
                        </h2>

                        <p class="text-xl md:text-2xl font-medium text-white-text mb-4">
                            One Platform. Six Semesters. Unlimited Learning.
                        </p>

                        <p class="text-light-gray/80 text-base md:text-lg mb-10 leading-relaxed max-w-xl">
                            A centralized legal education platform bringing together academic resources, reference materials, internships, and updates in one organized place—making learning simpler, faster, and more accessible.
                        </p>

                        <div class="flex flex-wrap gap-4">
                            <a href="/resource.html" class="btn-primary w-full sm:w-auto px-6 py-3.5 rounded-lg font-medium text-base inline-flex justify-center items-center gap-2">
                                <i class="ph ph-books text-xl"></i> Explore Resources
                            </a>
                            <a href="/internship.html" class="btn-secondary w-full sm:w-auto px-6 py-3.5 rounded-lg font-medium text-base inline-flex justify-center items-center gap-2">
                                <i class="ph ph-briefcase text-xl"></i> Explore Internships
                            </a>
                        </div>
                    </div>

                    <div class="hidden lg:flex justify-center items-center relative reveal delay-200">
                        <div class="absolute inset-0 bg-royal-blue/20 blur-[100px] rounded-full"></div>
                        <div class="relative w-80 h-96 glass-card rounded-2xl flex flex-col items-center justify-center p-8 border border-royal-blue/30 overflow-hidden group">
                            <div class="absolute inset-0 bg-[linear-gradient(rgba(30,77,255,0.1)_1px,transparent_1px),linear-gradient(90deg,rgba(30,77,255,0.1)_1px,transparent_1px)] bg-[size:20px_20px] opacity-20 group-hover:opacity-40 transition-opacity"></div>
                            <i class="ph-fill ph-scales text-9xl text-gold drop-shadow-[0_0_20px_rgba(212,175,55,0.4)] mb-6 transform group-hover:scale-105 transition-transform duration-500"></i>
                            <div class="w-full h-px bg-gradient-to-r from-transparent via-gold to-transparent opacity-50 mb-6"></div>
                            <div class="flex items-center gap-4 text-light-gray">
                                <div class="flex flex-col items-center">
                                    <i class="ph ph-files text-2xl text-royal-yellow mb-1"></i>
                                    <span class="text-xs">Notes</span>
                                </div>
                                <div class="w-px h-8 bg-light-gray/20"></div>
                                <div class="flex flex-col items-center">
                                    <i class="ph ph-gavel text-2xl text-royal-yellow mb-1"></i>
                                    <span class="text-xs">Cases</span>
                                </div>
                                <div class="w-px h-8 bg-light-gray/20"></div>
                                <div class="flex flex-col items-center">
                                    <i class="ph ph-briefcase text-2xl text-royal-yellow mb-1"></i>
                                    <span class="text-xs">Jobs</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Quick Access -->
            <section class="py-24 bg-deep-navy relative overflow-hidden">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-royal-blue/10 via-deep-navy to-rich-black"></div>
                <div class="container mx-auto px-6 md:px-12 relative z-10">
                    <div class="text-center mb-16 reveal">
                        <h2 class="font-heading text-3xl md:text-5xl font-bold mb-4">Quick Access</h2>
                        <p class="text-light-gray max-w-2xl mx-auto">Navigate directly to the core pillars of your legal education journey.</p>
                    </div>

                    <div class="grid md:grid-cols-2 gap-8">
                        <div class="glass-card rounded-2xl p-8 md:p-12 relative overflow-hidden group reveal">
                            <div class="absolute -right-10 -top-10 w-40 h-40 bg-royal-blue/20 rounded-full blur-2xl group-hover:bg-royal-blue/40 transition-colors"></div>
                            <i class="ph-fill ph-books text-5xl text-gold mb-6"></i>
                            <h3 class="text-2xl font-bold text-white-text mb-4 font-heading">Academic Resources</h3>
                            <p class="text-light-gray mb-8 leading-relaxed">
                                Access semester-wise notes, books, bare acts, previous year papers, and comprehensively organized academic materials.
                            </p>
                            <a href="/resource.html" class="inline-flex items-center gap-2 text-royal-yellow font-medium hover:gap-4 transition-all">
                                Explore Resources <i class="ph ph-arrow-right"></i>
                            </a>
                        </div>

                        <div class="glass-card rounded-2xl p-8 md:p-12 relative overflow-hidden group reveal delay-100">
                            <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-gold/10 rounded-full blur-2xl group-hover:bg-gold/20 transition-colors"></div>
                            <i class="ph-fill ph-briefcase text-5xl text-royal-blue mb-6"></i>
                            <h3 class="text-2xl font-bold text-white-text mb-4 font-heading">Internships & Careers</h3>
                            <p class="text-light-gray mb-8 leading-relaxed">
                                Discover internship opportunities with top law firms, supreme/high courts, NGOs, legal startups, and prominent organizations.
                            </p>
                            <a href="/internship.html" class="inline-flex items-center gap-2 text-royal-yellow font-medium hover:gap-4 transition-all">
                                View Opportunities <i class="ph ph-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Latest News & Updates — now driven by MongoDB content published by CMS -->
            <section class="py-24 bg-rich-black">
                <div class="container mx-auto px-6 md:px-12">
                    <div class="flex justify-between items-end mb-12 reveal">
                        <div>
                            <h2 class="font-heading text-3xl md:text-5xl font-bold mb-3">Latest Updates</h2>
                            <p class="text-light-gray">Stay informed with the newest additions and announcements.</p>
                        </div>
                        <a href="/news.html" class="hidden md:inline-flex items-center gap-2 text-light-gray hover:text-royal-yellow transition-colors border-b border-transparent hover:border-royal-yellow pb-1">
                            View All <i class="ph ph-arrow-right"></i>
                        </a>
                    </div>

                    <% if (latestNews && latestNews.length) { %>
                        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                            <% latestNews.forEach((item, i) => { %>
                                <a href="/<%= item.type === 'internship' ? 'internship' : item.type === 'case' ? 'cases' : item.type === 'book' || item.type === 'bareact' ? 'books' : item.type === 'resource' ? 'resource' : 'news' %>.html" class="glass-card p-6 rounded-xl flex flex-col group cursor-pointer reveal <%= i > 0 ? 'delay-' + (i * 100) : '' %> hover:bg-deep-navy/30">
                                    <div class="flex items-center justify-between mb-4">
                                        <span class="text-xs font-semibold px-2 py-1 bg-royal-blue/20 text-royal-blue rounded capitalize"><%= item.category || item.type %></span>
                                        <span class="text-xs text-light-gray/60"><%= new Date(item.createdAt).toLocaleDateString() %></span>
                                    </div>
                                    <h4 class="font-bold text-white-text mb-2 group-hover:text-gold transition-colors"><%= item.title %></h4>
                                    <p class="text-sm text-light-gray mb-4 flex-1 line-clamp-3"><%= item.description || '' %></p>
                                    <div class="mt-auto flex justify-end">
                                        <i class="ph ph-arrow-up-right text-light-gray group-hover:text-gold transition-colors"></i>
                                    </div>
                                </a>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="glass-card rounded-2xl p-12 text-center reveal">
                            <i class="ph ph-tray text-4xl text-light-gray/40 mb-4"></i>
                            <p class="text-light-gray">No updates published yet. Content uploaded by the CMS team and approved by an Admin will appear here automatically.</p>
                        </div>
                    <% } %>

                    <div class="mt-8 text-center md:hidden reveal">
                        <a href="/news.html" class="btn-secondary px-6 py-2.5 rounded-lg inline-block w-full">View All Updates</a>
                    </div>
                </div>
            </section>

            <!-- Why Choose Section -->
            <section class="py-24 bg-deep-navy relative border-y border-gold/10">
                <div class="container mx-auto px-6 md:px-12">
                    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
                        <h2 class="font-heading text-3xl md:text-5xl font-bold mb-4 text-white-text">Why Choose LEX Briefly?</h2>
                        <p class="text-light-gray">Designed with precision for law students, eliminating the clutter and focusing on what truly matters.</p>
                    </div>

                    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                        <div class="text-center reveal">
                            <div class="w-16 h-16 mx-auto rounded-2xl bg-royal-blue/20 border border-royal-blue/30 flex items-center justify-center mb-6">
                                <i class="ph-fill ph-stack text-3xl text-royal-blue"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-2 text-white-text">Comprehensive Resources</h4>
                            <p class="text-sm text-light-gray">Organized study materials meticulously categorized for every semester and subject.</p>
                        </div>

                        <div class="text-center reveal delay-100">
                            <div class="w-16 h-16 mx-auto rounded-2xl bg-gold/10 border border-gold/30 flex items-center justify-center mb-6">
                                <i class="ph-fill ph-seal-check text-3xl text-gold"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-2 text-white-text">Verified Legal Content</h4>
                            <p class="text-sm text-light-gray">Every upload is reviewed and published by an administrator before it goes live.</p>
                        </div>

                        <div class="text-center reveal delay-200">
                            <div class="w-16 h-16 mx-auto rounded-2xl bg-royal-blue/20 border border-royal-blue/30 flex items-center justify-center mb-6">
                                <i class="ph-fill ph-rocket-launch text-3xl text-royal-blue"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-2 text-white-text">Career Opportunities</h4>
                            <p class="text-sm text-light-gray">Curated internships and legal career opportunities curated in one central hub.</p>
                        </div>

                        <div class="text-center reveal delay-300">
                            <div class="w-16 h-16 mx-auto rounded-2xl bg-gold/10 border border-gold/30 flex items-center justify-center mb-6">
                                <i class="ph-fill ph-student text-3xl text-gold"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-2 text-white-text">Student-Centric</h4>
                            <p class="text-sm text-light-gray">Custom built specifically tailored for the needs of Faculty of Law, DU students.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Login Panel Preview -->
            <section id="login" class="py-12 bg-rich-black">
                <div class="container mx-auto px-6 md:px-6">
                    <div class="max-w-4xl mx-auto glass-card rounded-2xl overflow-hidden reveal">
                        <div class="grid md:grid-cols-1">
                            <div class="p-10 border-b md:border-b-0 md:border-r border-gold/10 hover:bg-deep-navy/30 transition-colors">
                                <div class="w-12 h-12 rounded-full bg-royal-blue/20 flex items-center justify-center mb-6">
                                    <i class="ph ph-user text-2xl text-royal-blue"></i>
                                </div>
                                <h3 class="font-heading font-bold text-2xl mb-2 text-white-text">Student Login</h3>
                                <p class="text-sm text-light-gray mb-6">Access your personalized dashboard.</p>
                                <ul class="space-y-3 mb-8 text-sm text-light-gray">
                                    <li class="flex items-center gap-2"><i class="ph-fill ph-check-circle text-gold"></i> Verified sign up with OTP</li>
                                    <li class="flex items-center gap-2"><i class="ph-fill ph-check-circle text-gold"></i> Browse all published resources</li>
                                    <li class="flex items-center gap-2"><i class="ph-fill ph-check-circle text-gold"></i> Secure, encrypted accounts</li>
                                </ul>
                                <div class="flex gap-2">
                                    <a href="/login" class="w-full btn-primary py-3 rounded-lg font-medium text-center">Login</a>
                                    <a href="/signup" class="w-full btn-secondary py-3 rounded-lg font-medium text-center">Sign Up</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>
    </div>

    <%- include('partials/scripts') %>
</body>
</html>