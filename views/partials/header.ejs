<header id="topHeader" class="fixed top-0 right-0 left-0 md:left-64 h-20 glass-header z-40 transition-all duration-300">
    <div class="flex items-center justify-between h-full px-4 md:px-8">
        <div class="flex items-center gap-4">
            <button id="mobileMenuBtn" class="md:hidden text-light-gray hover:text-white-text">
                <i class="ph ph-list text-3xl"></i>
            </button>
            <div class="hidden md:flex flex-col">
                <span class="text-xs font-semibold text-gold tracking-widest uppercase">University of Delhi</span>
                <span class="text-sm font-medium text-light-gray">Faculty of Law</span>
            </div>
        </div>

        <div class="flex-1 max-w-xl hidden lg:block mx-8">
            <div class="relative group">
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                    <i class="ph ph-magnifying-glass text-light-gray group-focus-within:text-royal-blue transition-colors"></i>
                </div>
                <input type="text" id="globalSearchInput" class="w-full bg-deep-navy/50 border border-gold/20 text-white-text text-sm rounded-full focus:ring-1 focus:ring-royal-blue focus:border-royal-blue block pl-12 p-3 transition-all placeholder-light-gray/50" placeholder="Search notes, books, case laws...">
                <div class="absolute inset-y-0 right-0 flex items-center pr-4">
                    <span class="text-xs text-light-gray/50 border border-light-gray/20 rounded px-1.5 py-0.5">Ctrl K</span>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-3 md:gap-5">
            <button class="relative text-light-gray hover:text-royal-yellow transition-colors">
                <i class="ph ph-bell text-2xl"></i>
                <span class="absolute top-0 right-0 w-2 h-2 bg-royal-yellow rounded-full"></span>
            </button>
            <button class="lg:hidden text-light-gray hover:text-royal-yellow transition-colors">
                <i class="ph ph-magnifying-glass text-2xl"></i>
            </button>

            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                <% const dashHref = currentUser.role === 'admin' ? '/admin/dashboard' : currentUser.role === 'cms' ? '/cms/dashboard' : '/dashboard'; %>
                <a href="<%= dashHref %>" class="hidden sm:flex btn-primary px-5 py-2.5 rounded-full font-medium text-sm items-center gap-2">
                    <i class="ph ph-user-circle text-lg"></i>
                    <span><%= currentUser.name.split(' ')[0] %></span>
                </a>
            <% } else { %>
                <a href="/login" class="hidden sm:flex btn-primary px-5 py-2.5 rounded-full font-medium text-sm items-center gap-2">
                    <span>Login</span>
                    <i class="ph ph-arrow-right font-bold"></i>
                </a>
            <% } %>
        </div>
    </div>
</header>