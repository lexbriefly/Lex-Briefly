<% var activePage = typeof active !== 'undefined' ? active : null; %>
<aside id="sidebar" class="fixed left-0 top-0 h-screen sidebar-expanded bg-rich-black border-r border-gold/10 z-50 transition-all duration-300 flex flex-col hidden md:flex">
    <div class="h-20 flex items-center justify-between px-4 border-b border-gold/10">
        <div class="flex items-center gap-3 overflow-hidden">
            <i class="ph-fill ph-scales text-3xl text-gold shrink-0"></i>
            <span class="font-heading font-bold text-xl text-white-text sidebar-text tracking-wide mt-1">LEX Briefly</span>
        </div>
        <button id="sidebarToggle" class="text-light-gray hover:text-royal-yellow transition-colors shrink-0 hidden md:block">
            <i class="ph ph-caret-left text-xl" id="sidebarIcon"></i>
        </button>
    </div>

    <nav class="flex-1 py-6 px-3 flex flex-col gap-2 overflow-y-auto overflow-x-hidden">
        <a href="/" class="flex items-center gap-4 px-3 py-3 rounded-lg <%= activePage === 'home' ? 'bg-royal-blue/10 text-royal-blue' : 'text-light-gray hover:bg-deep-navy hover:text-white-text' %> group transition-all">
            <i class="ph ph-house text-2xl group-hover:scale-110 transition-transform"></i>
            <span class="font-medium sidebar-text">Home</span>
        </a>
        <a href="/resource.html" class="flex items-center gap-4 px-3 py-3 rounded-lg <%= activePage === 'resources' ? 'bg-royal-blue/10 text-royal-blue' : 'text-light-gray hover:bg-deep-navy hover:text-white-text' %> group transition-all">
            <i class="ph ph-books text-2xl group-hover:text-gold group-hover:scale-110 transition-all"></i>
            <span class="font-medium sidebar-text">Resources</span>
        </a>
        <a href="/books.html" class="flex items-center gap-4 px-3 py-3 rounded-lg <%= activePage === 'books' ? 'bg-royal-blue/10 text-royal-blue' : 'text-light-gray hover:bg-deep-navy hover:text-white-text' %> group transition-all">
            <i class="ph ph-book-open-text text-2xl group-hover:text-gold group-hover:scale-110 transition-all"></i>
            <span class="font-medium sidebar-text">Books & Bare Acts</span>
        </a>
        <a href="/cases.html" class="flex items-center gap-4 px-3 py-3 rounded-lg <%= activePage === 'cases' ? 'bg-royal-blue/10 text-royal-blue' : 'text-light-gray hover:bg-deep-navy hover:text-white-text' %> group transition-all">
            <i class="ph ph-gavel text-2xl group-hover:text-gold group-hover:scale-110 transition-all"></i>
            <span class="font-medium sidebar-text">Case Laws</span>
        </a>
        <a href="/internship.html" class="flex items-center gap-4 px-3 py-3 rounded-lg <%= activePage === 'internships' ? 'bg-royal-blue/10 text-royal-blue' : 'text-light-gray hover:bg-deep-navy hover:text-white-text' %> group transition-all">
            <i class="ph ph-briefcase text-2xl group-hover:text-gold group-hover:scale-110 transition-all"></i>
            <span class="font-medium sidebar-text">Internships</span>
        </a>
        <a href="/news.html" class="flex items-center gap-4 px-3 py-3 rounded-lg <%= activePage === 'news' ? 'bg-royal-blue/10 text-royal-blue' : 'text-light-gray hover:bg-deep-navy hover:text-white-text' %> group transition-all">
            <i class="ph ph-newspaper text-2xl group-hover:text-gold group-hover:scale-110 transition-all"></i>
            <span class="font-medium sidebar-text">News & Updates</span>
        </a>
    </nav>

    <div class="p-4 border-t border-gold/10">
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
            <% const dashHref = currentUser.role === 'admin' ? '/admin/dashboard' : currentUser.role === 'cms' ? '/cms/dashboard' : '/dashboard'; %>
            <a href="<%= dashHref %>" class="flex items-center gap-4 px-3 py-3 rounded-lg text-light-gray hover:bg-royal-blue hover:text-white-text group transition-all">
                <i class="ph ph-squares-four text-2xl group-hover:text-royal-yellow transition-all"></i>
                <span class="font-medium sidebar-text">Dashboard</span>
            </a>
            <form action="/logout" method="POST">
                <button type="submit" class="w-full flex items-center gap-4 px-3 py-3 rounded-lg text-light-gray hover:bg-deep-navy hover:text-white-text group transition-all">
                    <i class="ph ph-sign-out text-2xl group-hover:text-gold transition-all"></i>
                    <span class="font-medium sidebar-text">Logout</span>
                </button>
            </form>
        <% } else { %>
            <a href="/login" class="flex items-center gap-4 px-3 py-3 rounded-lg text-light-gray hover:bg-royal-blue hover:text-white-text group transition-all">
                <i class="ph ph-sign-in text-2xl group-hover:text-royal-yellow transition-all"></i>
                <span class="font-medium sidebar-text">Login Panel</span>
            </a>
        <% } %>
    </div>
</aside>