<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <% var pageTitle = 'Admin Dashboard | LEX Briefly'; %>
    <%- include('../partials/head') %>
</head>
<body class="flex bg-rich-black text-white-text selection:bg-royal-blue selection:text-white-text">

    <%- include('../partials/sidebar') %>
    <%- include('../partials/mobile-drawer') %>

    <div id="mainContent" class="flex-1 transition-all duration-300 md:ml-64 relative min-h-screen">
        <%- include('../partials/header') %>

        <main class="pt-32 pb-20 px-6 md:px-12">
            <div class="max-w-6xl mx-auto">
                <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
                    <div>
                        <h1 class="font-heading text-3xl font-bold mb-1">Admin Dashboard</h1>
                        <p class="text-light-gray text-sm">Moderate content and manage CMS accounts.</p>
                    </div>
                    <div class="flex gap-3">
                        <a href="/admin/content-log" class="btn-secondary px-4 py-2 rounded-full text-sm flex items-center gap-2"><i class="ph ph-clipboard-text"></i> Content Log</a>
                        <a href="/admin/audit-log" class="btn-secondary px-4 py-2 rounded-full text-sm flex items-center gap-2"><i class="ph ph-list-checks"></i> Audit Log</a>
                    </div>
                </div>

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert-success mb-6 flex items-center gap-2"><i class="ph-fill ph-check-circle"></i><span><%= success %></span></div>
                <% } %>

                <div class="grid sm:grid-cols-4 gap-4 mb-10">
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-royal-yellow"><%= statusCounts.pending || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Pending</p>
                    </div>
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-green-400"><%= statusCounts.published || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Published</p>
                    </div>
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-red-400"><%= statusCounts.rejected || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Rejected</p>
                    </div>
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-royal-blue"><%= studentCount %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Students</p>
                    </div>
                </div>

                <div class="grid lg:grid-cols-5 gap-8 mb-10">
                    <!-- Pending content review -->
                    <div class="lg:col-span-3">
                        <div class="dash-card overflow-x-auto">
                            <h2 class="font-heading font-bold text-lg mb-4 flex items-center gap-2"><i class="ph ph-hourglass text-royal-yellow"></i> Pending Content (<%= pendingContent.length %>)</h2>
                            <table class="data-table">
                                <thead><tr><th>Title</th><th>Type</th><th>By</th><th>Actions</th></tr></thead>
                                <tbody id="pendingTableBody">
                                    <% pendingContent.forEach(function(item) { %>
                                        <tr id="row-<%= item._id %>">
                                            <td class="font-medium"><%= item.title %></td>
                                            <td class="text-light-gray"><%= item.type %></td>
                                            <td class="text-light-gray/70"><%= item.uploadedBy ? item.uploadedBy.email : '—' %></td>
                                            <td>
                                                <div class="flex gap-2">
                                                    <button data-action="publish" data-id="<%= item._id %>" class="text-green-400 hover:text-green-300" title="Publish"><i class="ph-fill ph-check-circle text-xl"></i></button>
                                                    <button data-action="reject" data-id="<%= item._id %>" class="text-red-400 hover:text-red-300" title="Reject"><i class="ph-fill ph-x-circle text-xl"></i></button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                    <% if (pendingContent.length === 0) { %>
                                        <tr><td colspan="4" class="text-center text-light-gray/60 py-8">Nothing pending review.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- CMS accounts -->
                    <div class="lg:col-span-2">
                        <div class="dash-card mb-6">
                            <h2 class="font-heading font-bold text-lg mb-4 flex items-center gap-2"><i class="ph ph-user-plus text-gold"></i> Issue CMS Account</h2>
                            <form action="/admin/cms-accounts" method="POST" class="space-y-3">
                                <div>
                                    <label class="form-label" for="cmsName">Name</label>
                                    <input class="form-input" type="text" id="cmsName" name="name" required>
                                </div>
                                <div>
                                    <label class="form-label" for="cmsEmail">Email</label>
                                    <input class="form-input" type="email" id="cmsEmail" name="email" required>
                                </div>
                                <button type="submit" class="btn-primary w-full py-2.5 rounded-xl font-semibold text-sm">Create &amp; Email Credentials</button>
                            </form>
                        </div>

                        <div class="dash-card overflow-x-auto">
                            <h2 class="font-heading font-bold text-lg mb-4 flex items-center gap-2"><i class="ph ph-users text-royal-blue"></i> CMS Accounts</h2>
                            <table class="data-table">
                                <thead><tr><th>Name</th><th>Status</th><th></th></tr></thead>
                                <tbody>
                                    <% cmsAccounts.forEach(function(u) { %>
                                        <tr id="cms-row-<%= u._id %>">
                                            <td>
                                                <div class="font-medium"><%= u.name %></div>
                                                <div class="text-light-gray/60 text-xs"><%= u.email %></div>
                                            </td>
                                            <td><span class="status-pill status-<%= u.status %>" id="cms-status-<%= u._id %>"><%= u.status %></span></td>
                                            <td>
                                                <button data-action="toggle-cms" data-id="<%= u._id %>" class="text-light-gray hover:text-white-text text-xs underline">
                                                    <%= u.status === 'active' ? 'Suspend' : 'Reactivate' %>
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                    <% if (cmsAccounts.length === 0) { %>
                                        <tr><td colspan="3" class="text-center text-light-gray/60 py-8">No CMS accounts yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('../partials/footer') %>
    </div>

    <%- include('../partials/scripts') %>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('[data-action="publish"], [data-action="reject"]').forEach((btn) => {
                btn.addEventListener('click', async () => {
                    const id = btn.getAttribute('data-id');
                    const action = btn.getAttribute('data-action');
                    const res = await fetch(`/admin/content/${id}/${action}`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        const row = document.getElementById(`row-${id}`);
                        if (row) row.remove();
                    }
                });
            });

            document.querySelectorAll('[data-action="toggle-cms"]').forEach((btn) => {
                btn.addEventListener('click', async () => {
                    const id = btn.getAttribute('data-id');
                    const res = await fetch(`/admin/cms-accounts/${id}/toggle`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        const pill = document.getElementById(`cms-status-${id}`);
                        if (pill) {
                            pill.textContent = data.status;
                            pill.className = `status-pill status-${data.status}`;
                        }
                        btn.textContent = data.status === 'active' ? 'Suspend' : 'Reactivate';
                    }
                });
            });
        });
    </script>
</body>
</html>
