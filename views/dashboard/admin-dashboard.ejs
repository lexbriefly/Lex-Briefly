<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <% var pageTitle = 'Admin Dashboard | LEX Briefly'; %>
    <%- include('../partials/head') %>
</head>
<body class="flex bg-rich-black text-white-text selection:bg-royal-blue selection:text-white-text">

    <%- include('../partials/sidebar') %>
    <%- include('../partials/mobile-drawer') %>

    <div id="mainContent" class="flex-1 transition-all duration-300 md:ml-64 relative min-h-screen">
        <%- include('../partials/header') %>

        <main class="pt-32 pb-20 px-6 md:px-12">
            <div class="max-w-6xl mx-auto">
                <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
                    <div>
                        <h1 class="font-heading text-3xl font-bold mb-1">Admin Dashboard</h1>
                        <p class="text-light-gray text-sm">Moderate content and manage CMS accounts.</p>
                    </div>
                    <div class="flex gap-3">
                        <a href="/admin/content-log" class="btn-secondary px-4 py-2 rounded-full text-sm flex items-center gap-2"><i class="ph ph-clipboard-text"></i> Content Log</a>
                        <a href="/admin/audit-log" class="btn-secondary px-4 py-2 rounded-full text-sm flex items-center gap-2"><i class="ph ph-list-checks"></i> Audit Log</a>
                    </div>
                </div>

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert-success mb-6 flex items-center gap-2"><i class="ph-fill ph-check-circle"></i><span><%= success %></span></div>
                <% } %>

                <div class="grid sm:grid-cols-4 gap-4 mb-10">
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-royal-yellow"><%= statusCounts.pending || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Pending</p>
                    </div>
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-green-400"><%= statusCounts.published || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Published</p>
                    </div>
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-red-400"><%= statusCounts.rejected || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Rejected</p>
                    </div>
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-royal-blue"><%= studentCount %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Students</p>
                    </div>
                </div>

                <div class="dash-card mb-10">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="font-heading font-bold text-lg flex items-center gap-2"><i class="ph ph-upload-simple text-gold"></i> Add Content Directly</h2>
                        <span class="status-pill status-published">publishes immediately</span>
                    </div>
                    <p class="text-light-gray text-sm mb-5">Same fields CMS staff use, but since you're the reviewer, anything you add here goes live right away — no review step.</p>

                    <form action="/admin/content" method="POST" enctype="multipart/form-data" class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="form-label" for="adminType">Content Type</label>
                            <select class="form-input" id="adminType" name="type" required>
                                <% contentTypes.forEach(function(t) { %>
                                    <option value="<%= t %>"><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div>
                            <label class="form-label" for="adminTitle">Title</label>
                            <input class="form-input" type="text" id="adminTitle" name="title" required>
                        </div>
                        <div>
                            <label class="form-label" for="adminSubtitle">Subtitle <span class="text-light-gray/50">(author / court / org)</span></label>
                            <input class="form-input" type="text" id="adminSubtitle" name="subtitle">
                        </div>
                        <div>
                            <label class="form-label" for="adminCategory">Category</label>
                            <input class="form-input" type="text" id="adminCategory" name="category" placeholder="e.g. Semester 3, Constitutional Law">
                        </div>
                        <div class="md:col-span-2">
                            <label class="form-label" for="adminDescription">Description</label>
                            <textarea class="form-input" id="adminDescription" name="description" rows="2"></textarea>
                        </div>
                        <div>
                            <label class="form-label" for="adminTags">Tags <span class="text-light-gray/50">(comma separated)</span></label>
                            <input class="form-input" type="text" id="adminTags" name="tags">
                        </div>

                        <!-- Resource-tile fields: only relevant when Content Type = Resource -->
                        <div id="adminResourceTileFields" class="hidden md:col-span-2 grid md:grid-cols-2 gap-4 border border-royal-blue/20 bg-royal-blue/5 rounded-xl p-4">
                            <div>
                                <label class="form-label" for="adminSemester">Semester</label>
                                <select class="form-input" id="adminSemester" name="semester">
                                    <option value="">Select semester…</option>
                                    <% semesters.forEach(function(sem) { %>
                                        <option value="<%= sem.key %>"><%= sem.label %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label" for="adminSubjectCode">Subject</label>
                                <select class="form-input" id="adminSubjectCode" name="subjectCode">
                                    <option value="">Select semester first…</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label" for="adminResourceCategory">Resource Tile</label>
                                <select class="form-input" id="adminResourceCategory" name="resourceCategory">
                                    <option value="">Select tile…</option>
                                    <% categories.forEach(function(cat) { %>
                                        <option value="<%= cat.key %>"><%= cat.icon %> <%= cat.label %></option>
                                    <% }); %>
                                </select>
                            </div>
                            <div>
                                <label class="form-label" for="adminTemplate">Upload Template</label>
                                <select class="form-input" id="adminTemplate" name="template">
                                    <% templates.forEach(function(t) { %>
                                        <option value="<%= t.key %>"><%= t.label %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>

                        <!-- Internship-specific fields: only relevant when Content Type = Internship -->
                        <div id="adminInternshipFields" class="hidden md:col-span-2 grid md:grid-cols-2 gap-4 border border-royal-blue/20 bg-royal-blue/5 rounded-xl p-4">
                            <div>
                                <label class="form-label" for="adminLocation">Location</label>
                                <input class="form-input" type="text" id="adminLocation" name="location" placeholder="e.g. New Delhi / Remote">
                            </div>
                            <div>
                                <label class="form-label" for="adminDurationWeeks">Time Period <span class="text-light-gray/50">(weeks)</span></label>
                                <input class="form-input" type="number" min="1" id="adminDurationWeeks" name="durationWeeks" placeholder="e.g. 8">
                            </div>
                            <div>
                                <label class="form-label" for="adminStipend">Allowance <span class="text-light-gray/50">(₹)</span></label>
                                <input class="form-input" type="number" min="0" id="adminStipend" name="stipend" placeholder="e.g. 10000">
                            </div>
                            <div>
                                <label class="form-label" for="adminStartDate">Starting Date</label>
                                <input class="form-input" type="date" id="adminStartDate" name="startDate">
                            </div>
                            <div class="md:col-span-2">
                                <label class="form-label" for="adminDeadline">Application Deadline <span class="text-light-gray/50">(optional)</span></label>
                                <input class="form-input" type="date" id="adminDeadline" name="deadline">
                            </div>
                        </div>

                        <div>
                            <label class="form-label" for="adminLink"><span id="adminLinkFieldLabel">External Link</span> <span class="text-light-gray/50">(optional)</span></label>
                            <input class="form-input" type="url" id="adminLink" name="link" placeholder="https://...">
                        </div>
                        <div class="md:col-span-2">
                            <label class="form-label" for="adminFile">File <span class="text-light-gray/50">(PDF / DOC / image, optional)</span></label>
                            <input class="form-input" type="file" id="adminFile" name="file" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                        </div>

                        <!-- Case Law-specific fields: only relevant when Content Type = Case -->
                        <div id="adminCaseFields" class="hidden md:col-span-2 grid md:grid-cols-2 gap-4 border border-royal-blue/20 bg-royal-blue/5 rounded-xl p-4">
                            <div>
                                <label class="form-label" for="adminCourt">Court</label>
                                <input class="form-input" type="text" id="adminCourt" name="court" placeholder="e.g. Supreme Court of India">
                            </div>
                            <div>
                                <label class="form-label" for="adminCitation">Citation</label>
                                <input class="form-input" type="text" id="adminCitation" name="citation" placeholder="e.g. (1973) 4 SCC 225">
                            </div>
                        </div>

                        <details class="md:col-span-2 text-sm">
                            <summary class="cursor-pointer text-light-gray hover:text-white-text">Type-specific fields (news)</summary>
                            <div class="mt-3 grid md:grid-cols-2 gap-3">
                                <div>
                                    <label class="form-label" for="adminPublishedDate">News Published Date</label>
                                    <input class="form-input" type="date" id="adminPublishedDate" name="publishedDate">
                                </div>
                            </div>
                        </details>


                        <div class="md:col-span-2">
                            <button type="submit" class="btn-primary w-full md:w-auto px-8 py-3 rounded-xl font-semibold text-sm">
                                Publish Now
                            </button>
                        </div>
                    </form>
                </div>

                <div class="grid lg:grid-cols-5 gap-8 mb-10">
                    <!-- Pending content review -->
                    <div class="lg:col-span-3">
                        <div class="dash-card overflow-x-auto">
                            <h2 class="font-heading font-bold text-lg mb-4 flex items-center gap-2"><i class="ph ph-hourglass text-royal-yellow"></i> Pending Content (<%= pendingContent.length %>)</h2>
                            <table class="data-table">
                                <thead><tr><th>Title</th><th>Type</th><th>By</th><th>Actions</th></tr></thead>
                                <tbody id="pendingTableBody">
                                    <% pendingContent.forEach(function(item) { %>
                                        <tr id="row-<%= item._id %>">
                                            <td class="font-medium"><%= item.title %></td>
                                            <td class="text-light-gray"><%= item.type %></td>
                                            <td class="text-light-gray/70"><%= item.uploadedBy ? item.uploadedBy.email : '—' %></td>
                                            <td>
                                                <div class="flex gap-2">
                                                    <button data-action="publish" data-id="<%= item._id %>" class="text-green-400 hover:text-green-300" title="Publish"><i class="ph-fill ph-check-circle text-xl"></i></button>
                                                    <button data-action="reject" data-id="<%= item._id %>" class="text-red-400 hover:text-red-300" title="Reject"><i class="ph-fill ph-x-circle text-xl"></i></button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                    <% if (pendingContent.length === 0) { %>
                                        <tr><td colspan="4" class="text-center text-light-gray/60 py-8">Nothing pending review.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- CMS accounts -->
                    <div class="lg:col-span-2">
                        <div class="dash-card mb-6">
                            <h2 class="font-heading font-bold text-lg mb-4 flex items-center gap-2"><i class="ph ph-user-plus text-gold"></i> Issue CMS Account</h2>
                            <form action="/admin/cms-accounts" method="POST" class="space-y-3">
                                <div>
                                    <label class="form-label" for="cmsName">Name</label>
                                    <input class="form-input" type="text" id="cmsName" name="name" required>
                                </div>
                                <div>
                                    <label class="form-label" for="cmsEmail">Email</label>
                                    <input class="form-input" type="email" id="cmsEmail" name="email" required>
                                </div>
                                <button type="submit" class="btn-primary w-full py-2.5 rounded-xl font-semibold text-sm">Create &amp; Email Credentials</button>
                            </form>
                        </div>

                        <div class="dash-card overflow-x-auto">
                            <h2 class="font-heading font-bold text-lg mb-4 flex items-center gap-2"><i class="ph ph-users text-royal-blue"></i> CMS Accounts</h2>
                            <table class="data-table">
                                <thead><tr><th>Name</th><th>Status</th><th></th></tr></thead>
                                <tbody>
                                    <% cmsAccounts.forEach(function(u) { %>
                                        <tr id="cms-row-<%= u._id %>">
                                            <td>
                                                <div class="font-medium"><%= u.name %></div>
                                                <div class="text-light-gray/60 text-xs"><%= u.email %></div>
                                            </td>
                                            <td><span class="status-pill status-<%= u.status %>" id="cms-status-<%= u._id %>"><%= u.status %></span></td>
                                            <td>
                                                <button data-action="toggle-cms" data-id="<%= u._id %>" class="text-light-gray hover:text-white-text text-xs underline">
                                                    <%= u.status === 'active' ? 'Suspend' : 'Reactivate' %>
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                    <% if (cmsAccounts.length === 0) { %>
                                        <tr><td colspan="3" class="text-center text-light-gray/60 py-8">No CMS accounts yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('../partials/footer') %>
    </div>

    <%- include('../partials/scripts') %>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('[data-action="publish"], [data-action="reject"]').forEach((btn) => {
                btn.addEventListener('click', async () => {
                    const id = btn.getAttribute('data-id');
                    const action = btn.getAttribute('data-action');
                    const res = await fetch(`/admin/content/${id}/${action}`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        const row = document.getElementById(`row-${id}`);
                        if (row) row.remove();
                    }
                });
            });

            document.querySelectorAll('[data-action="toggle-cms"]').forEach((btn) => {
                btn.addEventListener('click', async () => {
                    const id = btn.getAttribute('data-id');
                    const res = await fetch(`/admin/cms-accounts/${id}/toggle`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        const pill = document.getElementById(`cms-status-${id}`);
                        if (pill) {
                            pill.textContent = data.status;
                            pill.className = `status-pill status-${data.status}`;
                        }
                        btn.textContent = data.status === 'active' ? 'Suspend' : 'Reactivate';
                    }
                });
            });

            // --- Resource-tile fields on the "Add Content Directly" form ---
            const SUBJECTS_BY_SEMESTER = <%- JSON.stringify(subjectsBySemester) %>;
            const adminTypeSelect = document.getElementById('adminType');
            const adminTileFields = document.getElementById('adminResourceTileFields');
            const adminInternshipFields = document.getElementById('adminInternshipFields');
            const adminCaseFields = document.getElementById('adminCaseFields');
            const adminLinkFieldLabel = document.getElementById('adminLinkFieldLabel');
            const adminSemesterSelect = document.getElementById('adminSemester');
            const adminSubjectSelect = document.getElementById('adminSubjectCode');

            function toggleAdminResourceFields() {
                if (!adminTypeSelect) return;
                const isResource = adminTypeSelect.value === 'resource';
                const isInternship = adminTypeSelect.value === 'internship';
                const isCase = adminTypeSelect.value === 'case';
                if (adminTileFields) adminTileFields.classList.toggle('hidden', !isResource);
                if (adminInternshipFields) adminInternshipFields.classList.toggle('hidden', !isInternship);
                if (adminCaseFields) adminCaseFields.classList.toggle('hidden', !isCase);
                if (adminLinkFieldLabel) {
                    adminLinkFieldLabel.textContent = isInternship ? 'Apply Link' : (isCase ? 'Judgment Link' : 'External Link');
                }
            }
            function populateAdminSubjects() {
                const subjects = SUBJECTS_BY_SEMESTER[adminSemesterSelect.value] || [];
                adminSubjectSelect.innerHTML = '<option value="">Select subject…</option>' +
                    subjects.map((s) => `<option value="${s.code}">${s.code} — ${s.name}</option>`).join('');
            }
            if (adminTypeSelect) {
                adminTypeSelect.addEventListener('change', toggleAdminResourceFields);
                toggleAdminResourceFields();
            }
            if (adminSemesterSelect) adminSemesterSelect.addEventListener('change', populateAdminSubjects);
        });
    </script>
</body>
</html>