<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <% var pageTitle = 'CMS Dashboard | LEX Briefly'; %>
    <%- include('../partials/head') %>
</head>
<body class="flex bg-rich-black text-white-text selection:bg-royal-blue selection:text-white-text">

    <%- include('../partials/sidebar') %>
    <%- include('../partials/mobile-drawer') %>

    <div id="mainContent" class="flex-1 transition-all duration-300 md:ml-64 relative min-h-screen">
        <%- include('../partials/header') %>

        <main class="pt-32 pb-20 px-6 md:px-12">
            <div class="max-w-6xl mx-auto">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h1 class="font-heading text-3xl font-bold mb-1">CMS Dashboard</h1>
                        <p class="text-light-gray text-sm">Upload content for admin review before it goes live.</p>
                    </div>
                    <a href="/cms/change-password" class="btn-secondary px-4 py-2 rounded-full text-sm flex items-center gap-2">
                        <i class="ph ph-key"></i> Change Password
                    </a>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert-error mb-6 flex items-center gap-2"><i class="ph-fill ph-warning-circle"></i><span><%= error %></span></div>
                <% } %>
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert-success mb-6 flex items-center gap-2"><i class="ph-fill ph-check-circle"></i><span><%= success %></span></div>
                <% } %>

                <div class="grid sm:grid-cols-3 gap-4 mb-10">
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-royal-yellow"><%= statusCounts.pending || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Pending Review</p>
                    </div>
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-green-400"><%= statusCounts.published || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Published</p>
                    </div>
                    <div class="dash-card text-center">
                        <p class="text-3xl font-bold text-red-400"><%= statusCounts.rejected || 0 %></p>
                        <p class="text-light-gray text-xs uppercase tracking-wider mt-1">Rejected</p>
                    </div>
                </div>

                <div class="grid lg:grid-cols-5 gap-8">
                    <!-- Upload form -->
                    <div class="lg:col-span-2">
                        <div class="dash-card">
                            <h2 class="font-heading font-bold text-lg mb-4 flex items-center gap-2"><i class="ph ph-upload-simple text-gold"></i> New Content</h2>
                            <form action="/cms/content" method="POST" enctype="multipart/form-data" class="space-y-4">
                                <div>
                                    <label class="form-label" for="type">Content Type</label>
                                    <select class="form-input" id="type" name="type" required>
                                        <% contentTypes.forEach(function(t) { %>
                                            <option value="<%= t %>"><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label" for="title">Title</label>
                                    <input class="form-input" type="text" id="title" name="title" required>
                                </div>
                                <div>
                                    <label class="form-label" for="subtitle">Subtitle <span class="text-light-gray/50">(author / court / org)</span></label>
                                    <input class="form-input" type="text" id="subtitle" name="subtitle">
                                </div>
                                <div>
                                    <label class="form-label" for="description">Description</label>
                                    <textarea class="form-input" id="description" name="description" rows="3"></textarea>
                                </div>
                                <div>
                                    <label class="form-label" for="category">Category</label>
                                    <input class="form-input" type="text" id="category" name="category" placeholder="e.g. Semester 3, Constitutional Law">
                                </div>
                                <div>
                                    <label class="form-label" for="tags">Tags <span class="text-light-gray/50">(comma separated)</span></label>
                                    <input class="form-input" type="text" id="tags" name="tags">
                                </div>

                                <!-- Resource-tile fields: only relevant when Content Type = Resource.
                                     These tie the upload to one of the four tiles on a subject card
                                     (Case Materials / Notes & PDFs / PYQs / Video Classes). -->
                                <div id="resourceTileFields" class="hidden space-y-4 border border-royal-blue/20 bg-royal-blue/5 rounded-xl p-4">
                                    <p class="text-xs text-light-gray/70 flex items-center gap-2"><i class="ph ph-info text-royal-blue"></i> Choose exactly which tile on the Resources page this upload appears on.</p>
                                    <div>
                                        <label class="form-label" for="semester">Semester</label>
                                        <select class="form-input" id="semester" name="semester">
                                            <option value="">Select semester…</option>
                                            <% semesters.forEach(function(sem) { %>
                                                <option value="<%= sem.key %>"><%= sem.label %></option>
                                            <% }); %>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label" for="subjectCode">Subject</label>
                                        <select class="form-input" id="subjectCode" name="subjectCode">
                                            <option value="">Select semester first…</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label" for="resourceCategory">Resource Tile</label>
                                        <select class="form-input" id="resourceCategory" name="resourceCategory">
                                            <option value="">Select tile…</option>
                                            <% categories.forEach(function(cat) { %>
                                                <option value="<%= cat.key %>"><%= cat.icon %> <%= cat.label %></option>
                                            <% }); %>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label" for="template">Upload Template</label>
                                        <select class="form-input" id="template" name="template">
                                            <% templates.forEach(function(t) { %>
                                                <option value="<%= t.key %>"><%= t.label %></option>
                                            <% }); %>
                                        </select>
                                        <p id="templateHint" class="text-xs text-light-gray/60 mt-1.5"></p>
                                    </div>
                                </div>

                                <!-- Internship-specific fields: only relevant when Content Type = Internship -->
                                <div id="internshipFields" class="hidden space-y-4 border border-royal-blue/20 bg-royal-blue/5 rounded-xl p-4">
                                    <p class="text-xs text-light-gray/70 flex items-center gap-2"><i class="ph ph-info text-royal-blue"></i> These appear as the columns on the internship tile.</p>
                                    <div class="grid grid-cols-2 gap-3">
                                        <div>
                                            <label class="form-label" for="location">Location</label>
                                            <input class="form-input" type="text" id="location" name="location" placeholder="e.g. New Delhi / Remote">
                                        </div>
                                        <div>
                                            <label class="form-label" for="durationWeeks">Time Period <span class="text-light-gray/50">(weeks)</span></label>
                                            <input class="form-input" type="number" min="1" id="durationWeeks" name="durationWeeks" placeholder="e.g. 8">
                                        </div>
                                        <div>
                                            <label class="form-label" for="stipend">Allowance <span class="text-light-gray/50">(₹)</span></label>
                                            <input class="form-input" type="number" min="0" id="stipend" name="stipend" placeholder="e.g. 10000">
                                        </div>
                                        <div>
                                            <label class="form-label" for="startDate">Starting Date</label>
                                            <input class="form-input" type="date" id="startDate" name="startDate">
                                        </div>
                                    </div>
                                    <div>
                                        <label class="form-label" for="deadline">Application Deadline <span class="text-light-gray/50">(optional)</span></label>
                                        <input class="form-input" type="date" id="deadline" name="deadline">
                                    </div>
                                </div>

                                <div id="linkField">
                                    <label class="form-label" for="link"><span id="linkFieldLabel">External Link</span> <span class="text-light-gray/50" id="linkFieldHint">(optional)</span></label>
                                    <input class="form-input" type="url" id="link" name="link" placeholder="https://...">
                                </div>
                                <div id="fileField">
                                    <label class="form-label" for="file">File <span class="text-light-gray/50">(PDF / DOC / image, optional)</span></label>
                                    <input class="form-input" type="file" id="file" name="file" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                                </div>

                                <details class="text-sm">
                                    <summary class="cursor-pointer text-light-gray hover:text-white-text">Type-specific fields (news, cases)</summary>
                                    <div class="mt-3 space-y-3">
                                        <div>
                                            <label class="form-label" for="publishedDate">News Published Date</label>
                                            <input class="form-input" type="date" id="publishedDate" name="publishedDate">
                                        </div>
                                        <div>
                                            <label class="form-label" for="court">Case Court</label>
                                            <input class="form-input" type="text" id="court" name="court">
                                        </div>
                                        <div>
                                            <label class="form-label" for="citation">Case Citation</label>
                                            <input class="form-input" type="text" id="citation" name="citation">
                                        </div>
                                    </div>
                                </details>

                                <button type="submit" class="btn-primary w-full py-3 rounded-xl font-semibold text-sm">
                                    Submit for Review
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Content list -->
                    <div class="lg:col-span-3">
                        <div class="dash-card overflow-x-auto">
                            <h2 class="font-heading font-bold text-lg mb-4 flex items-center gap-2"><i class="ph ph-stack text-gold"></i> My Submissions</h2>
                            <table class="data-table">
                                <thead>
                                    <tr><th>Title</th><th>Type</th><th>Tile</th><th>Status</th><th>Submitted</th></tr>
                                </thead>
                                <tbody>
                                    <% items.forEach(function(item) { %>
                                        <tr>
                                            <td class="font-medium"><%= item.title %></td>
                                            <td class="text-light-gray"><%= item.type %></td>
                                            <td class="text-light-gray/70 text-xs">
                                                <% if (item.type === 'resource' && item.subjectCode) { %>
                                                    <%= item.subjectCode %> · <%= item.resourceCategory %>
                                                <% } else { %>—<% } %>
                                            </td>
                                            <td><span class="status-pill status-<%= item.status %>"><%= item.status %></span></td>
                                            <td class="text-light-gray/70"><%= new Date(item.createdAt).toLocaleDateString() %></td>
                                        </tr>
                                    <% }); %>
                                    <% if (items.length === 0) { %>
                                        <tr><td colspan="5" class="text-center text-light-gray/60 py-8">No submissions yet.</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('../partials/footer') %>
    </div>

    <%- include('../partials/scripts') %>
    <script>
        // Subjects per semester, mirrored from utils/subjectsCatalog.js on the server
        const SUBJECTS_BY_SEMESTER = <%- JSON.stringify(subjectsBySemester) %>;
        const TEMPLATE_HINTS = <%- JSON.stringify((templates || []).reduce((acc, t) => { acc[t.key] = t.hint; return acc; }, {})) %>;

        document.addEventListener('DOMContentLoaded', () => {
            const typeSelect = document.getElementById('type');
            const tileFields = document.getElementById('resourceTileFields');
            const internshipFields = document.getElementById('internshipFields');
            const semesterSelect = document.getElementById('semester');
            const subjectSelect = document.getElementById('subjectCode');
            const templateSelect = document.getElementById('template');
            const templateHint = document.getElementById('templateHint');
            const linkField = document.getElementById('linkField');
            const linkInput = document.getElementById('link');
            const linkFieldHint = document.getElementById('linkFieldHint');
            const linkFieldLabel = document.getElementById('linkFieldLabel');
            const fileField = document.getElementById('fileField');
            const fileInput = document.getElementById('file');

            function toggleResourceFields() {
                const isResource = typeSelect.value === 'resource';
                const isInternship = typeSelect.value === 'internship';

                tileFields.classList.toggle('hidden', !isResource);
                internshipFields.classList.toggle('hidden', !isInternship);

                if (isResource) {
                    applyTemplate();
                } else if (isInternship) {
                    linkField.classList.remove('hidden');
                    fileField.classList.remove('hidden');
                    linkFieldLabel.textContent = 'Apply Link';
                    linkInput.placeholder = 'https://... (application form / careers page)';
                    linkFieldHint.textContent = '(shown as the "Apply Now" button)';
                } else {
                    linkField.classList.remove('hidden');
                    fileField.classList.remove('hidden');
                    linkFieldLabel.textContent = 'External Link';
                    linkInput.placeholder = 'https://...';
                    linkFieldHint.textContent = '(optional)';
                }
            }

            function populateSubjects() {
                const subjects = SUBJECTS_BY_SEMESTER[semesterSelect.value] || [];
                subjectSelect.innerHTML = '<option value="">Select subject…</option>' +
                    subjects.map((s) => `<option value="${s.code}">${s.code} — ${s.name}</option>`).join('');
            }

            function applyTemplate() {
                const tpl = templateSelect.value;
                templateHint.textContent = TEMPLATE_HINTS[tpl] || '';
                linkFieldLabel.textContent = 'External Link';

                if (tpl === 'video') {
                    linkField.classList.remove('hidden');
                    fileField.classList.add('hidden');
                    fileInput.value = '';
                    linkInput.placeholder = 'https://youtube.com/watch?v=...';
                    linkFieldHint.textContent = '(paste the video link)';
                } else if (tpl === 'pdf') {
                    linkField.classList.remove('hidden');
                    fileField.classList.remove('hidden');
                    linkInput.placeholder = 'https://... (direct PDF link, optional if uploading a file)';
                    linkFieldHint.textContent = '(optional if you upload a file below)';
                } else {
                    linkField.classList.remove('hidden');
                    fileField.classList.remove('hidden');
                    linkInput.placeholder = 'https://...';
                    linkFieldHint.textContent = '(paste the reference link)';
                }
            }

            if (typeSelect) {
                typeSelect.addEventListener('change', toggleResourceFields);
                toggleResourceFields();
            }
            if (semesterSelect) semesterSelect.addEventListener('change', populateSubjects);
            if (templateSelect) templateSelect.addEventListener('change', applyTemplate);
        });
    </script>
</body>
</html>