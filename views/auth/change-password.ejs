<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <% var pageTitle = 'Change Password | LEX Briefly'; %>
    <%- include('../partials/head') %>
</head>
<body class="bg-rich-black text-white-text selection:bg-royal-blue selection:text-white-text">
    <div class="auth-shell">
        <div class="auth-card">
            <div class="text-center mb-8">
                <a href="/" class="inline-flex items-center gap-3 mb-4">
                    <i class="ph-fill ph-scales text-4xl text-gold"></i>
                    <span class="font-heading font-bold text-2xl text-white-text tracking-wide">LEX Briefly</span>
                </a>
                <h1 class="font-heading text-2xl font-bold">Change Password</h1>
                <% if (typeof forced !== 'undefined' && forced) { %>
                    <p class="text-royal-yellow text-sm mt-1">You must set a new password before continuing.</p>
                <% } else { %>
                    <p class="text-light-gray text-sm mt-1">Update your account password.</p>
                <% } %>
            </div>

            <div class="glass-card rounded-2xl p-8">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert-error mb-5 flex items-center gap-2">
                        <i class="ph-fill ph-warning-circle"></i>
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/cms/change-password" method="POST" class="space-y-4">
                    <div>
                        <label class="form-label" for="currentPassword">Current Password</label>
                        <input class="form-input" type="password" id="currentPassword" name="currentPassword" required placeholder="Your current / temporary password">
                    </div>
                    <div>
                        <label class="form-label" for="newPassword">New Password</label>
                        <input class="form-input" type="password" id="newPassword" name="newPassword" required minlength="8" placeholder="At least 8 characters">
                    </div>
                    <div>
                        <label class="form-label" for="confirmPassword">Confirm New Password</label>
                        <input class="form-input" type="password" id="confirmPassword" name="confirmPassword" required minlength="8" placeholder="Re-enter new password">
                    </div>

                    <button type="submit" class="btn-primary w-full py-3 rounded-xl font-semibold text-sm mt-2">
                        Update Password
                    </button>
                </form>

                <% if (!(typeof forced !== 'undefined' && forced)) { %>
                    <p class="text-center text-light-gray text-sm mt-6">
                        <a href="/cms/dashboard" class="text-royal-yellow hover:underline font-medium">&larr; Back to dashboard</a>
                    </p>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
