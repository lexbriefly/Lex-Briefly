<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <% var pageTitle = 'About Us | LEX Briefly'; %>
    <%- include('partials/head') %>
</head>
<body class="flex bg-rich-black text-white-text selection:bg-royal-blue selection:text-white-text">

    <%- include('partials/sidebar') %>
    <%- include('partials/mobile-drawer') %>

    <div id="mainContent" class="flex-1 transition-all duration-300 md:ml-64 relative min-h-screen">
        <%- include('partials/header') %>

        <main class="pt-20">
            <!-- Hero -->
            <section class="relative min-h-[40vh] flex items-center py-16 overflow-hidden bg-hero-pattern border-b border-gold/10">
                <canvas id="particle-canvas"></canvas>
                <svg class="watermark" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
                    <path d="M224,112h-84.4l-7.3-65.7a8,8,0,0,0-15.9,1.7l7.1,64H40a8,8,0,0,0,0,16H98.9l-19.1,66.8A24,24,0,0,0,103,222.1l1.5-.4A24.1,24.1,0,0,0,120,200l17.7-61.9L155.4,200a24.1,24.1,0,0,0,15.5,21.7l1.5.4a24,24,0,0,0,23.2-27.3l-19.1-66.8H224a8,8,0,0,0,0-16ZM102,192.3l15-52.5,15,52.5a8.1,8.1,0,0,1-5.1,10,8.2,8.2,0,0,1-19.8-10Zm61,10a8.1,8.1,0,0,1-5.1-10l15-52.5,15,52.5a8.2,8.2,0,0,1-19.8,10ZM128,40a8,8,0,0,0,8-8V16a8,8,0,0,0-16,0V32A8,8,0,0,0,128,40Z"/>
                </svg>
                <div class="container mx-auto px-6 md:px-12 relative z-10 text-center">
                    <div class="reveal max-w-3xl mx-auto">
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-gold/30 bg-deep-navy/50 text-gold text-xs font-semibold uppercase tracking-wider mb-6 backdrop-blur-sm">
                            <i class="ph-fill ph-info text-royal-yellow"></i> Who We Are
                        </div>
                        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-4 drop-shadow-xl text-white-text">About Us</h1>
                        <p class="text-light-gray/80 text-base md:text-lg mb-2 max-w-2xl mx-auto leading-relaxed">
                            LEX Briefly is a student-built initiative from the Faculty of Law, University of Delhi — created to make legal education simpler, faster, and more accessible for everyone.
                        </p>
                    </div>
                </div>
            </section>

            <!-- Our Story -->
            <section class="py-24 bg-deep-navy relative overflow-hidden">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-royal-blue/10 via-deep-navy to-rich-black"></div>
                <div class="container mx-auto px-6 md:px-12 relative z-10 grid lg:grid-cols-2 gap-12 items-center">
                    <div class="reveal">
                        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-6 text-white-text">Our Story</h2>
                        <p class="text-light-gray leading-relaxed mb-4">
                            LEX Briefly began with a simple observation — law students at the Faculty of Law, University of Delhi were juggling notes, bare acts, case summaries, and internship listings scattered across group chats, drives, and photocopied handouts.
                        </p>
                        <p class="text-light-gray leading-relaxed mb-4">
                            We set out to build one organized home for all of it — semester-wise resources, verified reference material, and career opportunities, reviewed and published transparently by a dedicated CMS and Admin team.
                        </p>
                        <p class="text-light-gray leading-relaxed">
                            What started as a small idea is now growing into a platform built by students, for students — and it keeps improving with every contribution.
                        </p>
                    </div>
                    <div class="glass-card rounded-2xl p-8 md:p-10 relative overflow-hidden group reveal delay-100">
                        <div class="absolute -right-10 -top-10 w-40 h-40 bg-royal-blue/20 rounded-full blur-2xl group-hover:bg-royal-blue/40 transition-colors"></div>
                        <i class="ph-fill ph-target text-5xl text-gold mb-6"></i>
                        <h3 class="text-2xl font-bold text-white-text mb-4 font-heading">Our Mission</h3>
                        <p class="text-light-gray leading-relaxed">
                            To centralize legal education resources for Faculty of Law students, removing clutter and friction from academic life so students can focus on learning, not searching.
                        </p>
                        <div class="w-full h-px bg-gradient-to-r from-transparent via-gold to-transparent opacity-50 my-6"></div>
                        <i class="ph-fill ph-eye text-5xl text-royal-blue mb-6"></i>
                        <h3 class="text-2xl font-bold text-white-text mb-4 font-heading">Our Vision</h3>
                        <p class="text-light-gray leading-relaxed">
                            A trusted, student-driven legal learning ecosystem that scales beyond one faculty — organized, verified, and always evolving.
                        </p>
                    </div>
                </div>
            </section>

            <!-- What We Stand For -->
            <section class="py-24 bg-rich-black relative border-y border-gold/10">
                <div class="container mx-auto px-6 md:px-12">
                    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
                        <h2 class="font-heading text-3xl md:text-5xl font-bold mb-4 text-white-text">What We Stand For</h2>
                        <p class="text-light-gray">The principles that shape every feature we build and every upload we approve.</p>
                    </div>

                    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                        <div class="text-center reveal">
                            <div class="w-16 h-16 mx-auto rounded-2xl bg-royal-blue/20 border border-royal-blue/30 flex items-center justify-center mb-6">
                                <i class="ph-fill ph-seal-check text-3xl text-royal-blue"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-2 text-white-text">Verified Content</h4>
                            <p class="text-sm text-light-gray">Every resource is reviewed by our team before it ever reaches students.</p>
                        </div>

                        <div class="text-center reveal delay-100">
                            <div class="w-16 h-16 mx-auto rounded-2xl bg-gold/10 border border-gold/30 flex items-center justify-center mb-6">
                                <i class="ph-fill ph-users-three text-3xl text-gold"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-2 text-white-text">Built by Students</h4>
                            <p class="text-sm text-light-gray">Designed by law students who understand exactly what the syllabus demands.</p>
                        </div>

                        <div class="text-center reveal delay-200">
                            <div class="w-16 h-16 mx-auto rounded-2xl bg-royal-blue/20 border border-royal-blue/30 flex items-center justify-center mb-6">
                                <i class="ph-fill ph-lock-key text-3xl text-royal-blue"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-2 text-white-text">Secure & Transparent</h4>
                            <p class="text-sm text-light-gray">Encrypted accounts and a clear content-approval trail for every upload.</p>
                        </div>

                        <div class="text-center reveal delay-300">
                            <div class="w-16 h-16 mx-auto rounded-2xl bg-gold/10 border border-gold/30 flex items-center justify-center mb-6">
                                <i class="ph-fill ph-plant text-3xl text-gold"></i>
                            </div>
                            <h4 class="font-bold text-lg mb-2 text-white-text">Always Growing</h4>
                            <p class="text-sm text-light-gray">New subjects, features, and opportunities added as the community grows.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Contributors -->
            <section class="py-24 bg-deep-navy relative overflow-hidden">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_var(--tw-gradient-stops))] from-gold/5 via-deep-navy to-rich-black"></div>
                <div class="container mx-auto px-6 md:px-12 relative z-10">
                    <div class="text-center max-w-2xl mx-auto mb-16 reveal">
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-gold/30 bg-deep-navy/50 text-gold text-xs font-semibold uppercase tracking-wider mb-6 backdrop-blur-sm">
                            <i class="ph-fill ph-users text-royal-yellow"></i> The Team
                        </div>
                        <h2 class="font-heading text-3xl md:text-5xl font-bold mb-4 text-white-text">Contributors</h2>
                        <p class="text-light-gray">The people building and maintaining LEX Briefly, one commit and one upload at a time.</p>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                        <!-- Contributor Card 1 -->
                        <div class="glass-card rounded-2xl p-8 text-center relative overflow-hidden group reveal">
                            <div class="absolute -right-8 -top-8 w-32 h-32 bg-royal-blue/20 rounded-full blur-2xl group-hover:bg-royal-blue/40 transition-colors"></div>
                            <div class="w-20 h-20 mx-auto rounded-full bg-royal-blue/20 border-2 border-royal-blue/40 flex items-center justify-center mb-5 relative z-10">
                                <i class="ph-fill ph-user text-4xl text-royal-blue"></i>
                            </div>
                            <h4 class="font-heading font-bold text-lg text-white-text mb-1">Anurag Sharma</h4>
                            <p class="text-xs text-gold uppercase tracking-wider font-semibold mb-4">Founder & Lead Developer</p>
                            <p class="text-sm text-light-gray mb-5 leading-relaxed">Conceived the idea for LEX Briefly from the ground up for the Faculty of Law.</p>
                            <div class="flex justify-center gap-3">
                                <a href="https://www.linkedin.com" class="w-9 h-9 rounded-full bg-deep-navy border border-gold/20 flex items-center justify-center text-light-gray hover:bg-royal-blue hover:text-white-text hover:border-royal-blue transition-all">
                                    <i class="ph-fill ph-linkedin-logo">Anurag</i>
                                </a>
                                <a href="https://instagram.com" class="w-9 h-9 rounded-full bg-deep-navy border border-gold/20 flex items-center justify-center text-light-gray hover:bg-royal-blue hover:text-white-text hover:border-royal-blue transition-all">
                                    <i class="ph-fill ph-instagram-logo">Anurag</i>
                                </a>
                            </div>
                        </div>

                        <!-- Contributor Card 2 -->
                        <div class="glass-card rounded-2xl p-8 text-center relative overflow-hidden group reveal delay-100">
                            <div class="absolute -right-8 -top-8 w-32 h-32 bg-gold/10 rounded-full blur-2xl group-hover:bg-gold/20 transition-colors"></div>
                            <div class="w-20 h-20 mx-auto rounded-full bg-gold/10 border-2 border-gold/40 flex items-center justify-center mb-5 relative z-10">
                                <i class="ph-fill ph-user text-4xl text-gold"></i>
                            </div>
                            <h4 class="font-heading font-bold text-lg text-white-text mb-1">Aman Agastya</h4>
                            <p class="text-xs text-gold uppercase tracking-wider font-semibold mb-4">Build this LEX Briefly from the ground up and add own ideas with it.</p>
                            <div class="flex justify-center gap-3">
                                <a href="#" class="w-9 h-9 rounded-full bg-deep-navy border border-gold/20 flex items-center justify-center text-light-gray hover:bg-royal-blue hover:text-white-text hover:border-royal-blue transition-all">
                                    <i class="ph-fill ph-linkedin-logo"></i>
                                </a>
                                <a href="#" class="w-9 h-9 rounded-full bg-deep-navy border border-gold/20 flex items-center justify-center text-light-gray hover:bg-royal-blue hover:text-white-text hover:border-royal-blue transition-all">
                                    <i class="ph-fill ph-instagram-logo"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Contributor Card 3 -->
                        <div class="glass-card rounded-2xl p-8 text-center relative overflow-hidden group reveal delay-200">
                            <div class="absolute -right-8 -top-8 w-32 h-32 bg-royal-blue/20 rounded-full blur-2xl group-hover:bg-royal-blue/40 transition-colors"></div>
                            <div class="w-20 h-20 mx-auto rounded-full bg-royal-blue/20 border-2 border-royal-blue/40 flex items-center justify-center mb-5 relative z-10">
                                <i class="ph-fill ph-user text-4xl text-royal-blue"></i>
                            </div>
                            <h4 class="font-heading font-bold text-lg text-white-text mb-1">ABCD</h4>
                            <p class="text-xs text-gold uppercase tracking-wider font-semibold mb-4">Content & Curation</p>
                            <p class="text-sm text-light-gray mb-5 leading-relaxed">Reviews and organizes academic material across semesters and subjects.</p>
                            <div class="flex justify-center gap-3">
                                <a href="#" class="w-9 h-9 rounded-full bg-deep-navy border border-gold/20 flex items-center justify-center text-light-gray hover:bg-royal-blue hover:text-white-text hover:border-royal-blue transition-all">
                                    <i class="ph-fill ph-linkedin-logo">ABCD</i>
                                </a>
                                <a href="#" class="w-9 h-9 rounded-full bg-deep-navy border border-gold/20 flex items-center justify-center text-light-gray hover:bg-royal-blue hover:text-white-text hover:border-royal-blue transition-all">
                                    <i class="ph-fill ph-github-logo"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Contributor Card 4 -->
                        <div class="glass-card rounded-2xl p-8 text-center relative overflow-hidden group reveal delay-300">
                            <div class="absolute -right-8 -top-8 w-32 h-32 bg-gold/10 rounded-full blur-2xl group-hover:bg-gold/20 transition-colors"></div>
                            <div class="w-20 h-20 mx-auto rounded-full bg-gold/10 border-2 border-gold/40 flex items-center justify-center mb-5 relative z-10">
                                <i class="ph-fill ph-user text-4xl text-gold"></i>
                            </div>
                            <h4 class="font-heading font-bold text-lg text-white-text mb-1">XYZ</h4>
                            <p class="text-xs text-gold uppercase tracking-wider font-semibold mb-4">Outreach & Content</p>
                            <p class="text-sm text-light-gray mb-5 leading-relaxed">Sources internships and legal opportunities for the community.</p>
                            <div class="flex justify-center gap-3">
                                <a href="#" class="w-9 h-9 rounded-full bg-deep-navy border border-gold/20 flex items-center justify-center text-light-gray hover:bg-royal-blue hover:text-white-text hover:border-royal-blue transition-all">
                                    <i class="ph-fill ph-linkedin-logo">XYZ</i>
                                </a>
                                <a href="#" class="w-9 h-9 rounded-full bg-deep-navy border border-gold/20 flex items-center justify-center text-light-gray hover:bg-royal-blue hover:text-white-text hover:border-royal-blue transition-all">
                                    <i class="ph-fill ph-instagram-logo"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <p class="text-center text-xs text-light-gray/50 mt-10 reveal">
                        More contributors will be added here as the LEX Briefly team grows.
                    </p>
                </div>
            </section>

            <!-- CTA -->
            <section class="py-16 bg-rich-black">
                <div class="container mx-auto px-6">
                    <div class="max-w-3xl mx-auto glass-card rounded-2xl p-10 md:p-12 text-center reveal">
                        <i class="ph-fill ph-hand-heart text-5xl text-gold mb-6"></i>
                        <h3 class="font-heading font-bold text-2xl md:text-3xl mb-3 text-white-text">Want to Contribute?</h3>
                        <p class="text-sm md:text-base text-light-gray mb-8 max-w-xl mx-auto leading-relaxed">
                            Whether it's notes, case summaries, or internship leads — we welcome students who want to help grow LEX Briefly for the whole faculty.
                        </p>
                        <a href="mailto:lexbriefly@gmail.com" class="btn-primary inline-flex items-center gap-2 px-6 py-3.5 rounded-lg font-medium text-base">
                            <i class="ph ph-envelope-simple text-xl"></i> Get in Touch
                        </a>
                    </div>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>
    </div>

    <%- include('partials/scripts') %>
</body>
</html>